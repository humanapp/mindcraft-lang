{
  "name": "mindcraft-lbb",
  "description": "Little Big Brains - A Kodu-like Mindcraft experience",
  "version": "0.1.0",
  "type": "module",
  "author": "humanapp",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs --force",
    "prebuild": "cd ../../packages/core && npm run build",
    "build": "vite build --config vite/config.prod.mjs",
    "test": "node --import tsx --test test/terrain/*.test.ts",
    "clean": "rm -rf dist && rm -rf node_modules/.vite",
    "lint": "biome lint ./src ./test",
    "lint:fix": "biome lint ./src ./test --write",
    "format": "biome format ./src ./test --write",
    "format:check": "biome format ./src ./test",
    "check": "biome check ./src ./test",
    "check:fix": "biome check ./src ./test --write",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@mindcraft-lang/core": "file:../../packages/core",
    "@mindcraft-lang/docs": "file:../../packages/docs",
    "@mindcraft-lang/ui": "file:../../packages/ui",
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "terser": "^5.28.1",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vite-plugin-glsl": "^1.5.6"
  }
}
