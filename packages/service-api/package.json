{
  "name": "@mindcraft-lang/service-api",
  "version": "0.2.0",
  "description": "Request/response schemas, shared enums, error shapes, and serialization formats for the Mindcraft backend service API",
  "license": "MIT",
  "type": "module",
  "author": "humanapp",
  "repository": {
    "type": "git",
    "url": "https://github.com/humanapp/mindcraft-lang.git",
    "directory": "packages/service-api"
  },
  "bugs": {
    "url": "https://github.com/humanapp/mindcraft-lang/issues"
  },
  "homepage": "https://github.com/humanapp/mindcraft-lang/tree/main/packages/service-api#readme",
  "keywords": [
    "mindcraft",
    "visual-programming",
    "tile-based",
    "typescript",
    "api",
    "schemas",
    "education",
    "stem",
    "coding"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:prod": "tsc --build tsconfig.prod.json",
    "clean": "tsc --build --clean",
    "watch": "tsc --build --watch",
    "lint:only": "biome lint ./src",
    "check:only": "biome check ./src",
    "format:only": "biome format ./src",
    "lint": "biome lint ./src --write",
    "check": "biome check ./src --write",
    "typecheck": "tsc --noEmit",
    "format": "biome format ./src --write",
    "release:patch": "node ../../scripts/release.js patch",
    "release:minor": "node ../../scripts/release.js minor",
    "release:major": "node ../../scripts/release.js major"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "typescript": "~5.9.3"
  }
}
