{
  "name": "@mindcraft-lang/ui",
  "description": "Shared React UI components and brain editor for Mindcraft apps",
  "version": "0.1.6",
  "type": "module",
  "author": "humanapp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/humanapp/mindcraft-lang.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/humanapp/mindcraft-lang/issues"
  },
  "homepage": "https://github.com/humanapp/mindcraft-lang/tree/main/packages/ui#readme",
  "keywords": [
    "mindcraft",
    "visual-programming",
    "tile-based",
    "ui",
    "react",
    "brain-editor",
    "components",
    "education",
    "stem",
    "coding",
    "creative-coding"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "lint:only": "biome lint ./src",
    "check:only": "biome check ./src",
    "format:only": "biome format ./src",
    "lint": "biome lint ./src --write",
    "check": "biome check ./src --write",
    "typecheck": "tsc --noEmit",
    "format": "biome format ./src --write",
    "release:patch": "npm run check:only && node ../../scripts/release.js patch",
    "release:minor": "npm run check:only && node ../../scripts/release.js minor",
    "release:major": "npm run check:only && node ../../scripts/release.js major"
  },
  "dependencies": {
    "@mindcraft-lang/core": "file:../core",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "~5.9.3"
  }
}
