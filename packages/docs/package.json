{
  "name": "@mindcraft-lang/docs",
  "description": "Shared documentation sidebar and rendering components for Mindcraft apps",
  "version": "0.1.13",
  "type": "module",
  "author": "humanapp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/humanapp/mindcraft-lang.git",
    "directory": "packages/docs"
  },
  "bugs": {
    "url": "https://github.com/humanapp/mindcraft-lang/issues"
  },
  "homepage": "https://github.com/humanapp/mindcraft-lang/tree/main/packages/docs#readme",
  "keywords": [
    "mindcraft",
