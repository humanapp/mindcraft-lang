  "pages": [
    {
      "version": 2,
      "pageId": "dZZHT33qjL1pDuLw",
      "name": "Protect",
      "rules": [
        {
          "version": 1,
          "when": [
            "tile.sensor->sensor.see",
            "tile.modifier->modifier.actor_kind.carnivore"
          ],
          "do": [
            "tile.actuator->actuator.shoot",
            "tile.parameter->parameter.rate",
            "tile.literal->number:<number>->0.5"
          ],
          "children": [],
          "comment": "Shoot carnivores. We don't like them!"
        },
        {
          "version": 1,
          "when": [],
          "do": [],
          "children": []
        }
      ]
    }
  ]
}