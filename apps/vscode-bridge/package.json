{
	"name": "@mindcraft-lang/vscode-bridge",
	"version": "0.1.11",
	"private": true,
	"description": "VSCode bridge server for TypeScript authoring in Mindcraft",
	"type": "module",
	"imports": {
		"#package.json": "./package.json",
		"#*.js": {
			"types": "./src/*.ts",
			"development": "./src/*.ts",
			"default": "./dist/*.js"
		}
	},
	"scripts": {
		"dev": "tsx watch --conditions=development --env-file=.env src/index.ts",
		"build": "tsc --build",
		"start": "node --env-file=.env dist/index.js",
		"clean": "rm -rf dist",
		"lint:only": "biome lint ./src",
		"check:only": "biome check ./src",
		"format:only": "biome format ./src",
		"lint": "biome lint ./src --write",
		"check": "biome check ./src --write",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.spec.json",
		"format": "biome format ./src --write",
		"test": "tsx --conditions=development --test src/**/*.spec.ts",
		"test:watch": "tsx --conditions=development --test --watch src/**/*.spec.ts",
		"test:coverage": "tsx --conditions=development --test --experimental-test-coverage src/**/*.spec.ts",
		"release:patch": "node ../../scripts/release.js patch",
		"release:minor": "node ../../scripts/release.js minor",
		"release:major": "node ../../scripts/release.js major"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@hono/node-ws": "^1.3.0",
		"@mindcraft-lang/bridge-protocol": "file:../../packages/bridge-protocol",
		"hono": "^4.12.7",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@types/node": "^25.5.0",
		"pino-pretty": "^13.1.3",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3"
	}
}
