{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.3.15/schema.json",
  "extends": ["../../biome.json"],
  "formatter": {
    "useEditorconfig": true
  },
  "linter": {
    "rules": {
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/examples/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}

