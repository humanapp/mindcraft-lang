{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "preserveSymlinks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"],
  "references": [
    { "path": "../app-host/tsconfig.json" },
    { "path": "../bridge-client/tsconfig.json" },
    { "path": "../bridge-protocol/tsconfig.json" },
    { "path": "../core/tsconfig.esm.json" },
    { "path": "../ts-compiler/tsconfig.json" }
  ]
}
